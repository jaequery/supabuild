# Ignore everything
*

# Allowlist: marketplace catalog at root + plugin tree
!.claude-plugin/
!.claude-plugin/**
!plugins/
!plugins/**

# Allowlist: repo-level meta
!.gitignore
!README.md
!LICENSE

# Block runtime evidence artifacts even if they land inside allowlisted dirs
.supabuild/
.supabuild-design/
playwright-output/
playwright-report/
test-results/
node_modules/
*.webm
*.mp4
